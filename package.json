{
  "name": "vs-engine",
  "private": true,
  "type": "module",
  "workspaces": [
    "cocosVS/packages/*"
  ],
  "scripts": {
    "ascii": "node --import tsx scripts/run-ascii.ts",
    "ascii:dump": "node --import tsx scripts/run-ascii.ts --dump",
    "test": "node --import tsx --test $(find tests -name '*.test.ts' | sort)",
    "test:watch": "node --import tsx --test --watch $(find tests -name '*.test.ts' | sort)",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
